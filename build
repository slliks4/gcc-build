#!/usr/bin/env sh

OUTPUT_DIR="./output"

if [ -z "${1:-}" ]; then
    echo "Usage: $0 <filename.c> [run] [compiler options...]"
    echo "Example: $0 main.c run -lraylib -lm -lpthread -ldl -lrt -lX11"
    exit 1
fi

source_file="$1"
shift

should_run=false

if [ "${1:-}" = "run" ]; then
    should_run=true
    shift
fi

mkdir -p "$OUTPUT_DIR"

base_name=$(basename "$source_file" .c)
output_file="$OUTPUT_DIR/$base_name"

echo "Building $source_file..."
echo "Build name: $base_name"

# "$@" contains all remaining compiler/linker arguments.
if ! gcc -Wall -Wextra "$source_file" -o "$output_file" "$@"; then
    echo "Compilation failed!"
    exit 1
fi

echo "Build successful: $output_file"

if [ "$should_run" = true ]; then
    echo
    echo "-- Program Output --"
    "$output_file"
fi
